rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 1. GLOBAL SAFETY NET ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 2. GLOBAL HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      // Mandated by instructions: User email must be verified
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == 'wilsondayritjrapex@gmail.com' ||
        request.auth.token.email == 'nolascoceline014@gmail.com' ||
        request.auth.token.email == 'nolascoceline124@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'))
      );
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- 3. ENTITY VALIDATORS ---

    function isValidUser(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category']) &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0;
    }

    function isValidUserPrefs(data) {
      return (data.get('savedIds', []) is list) &&
             (data.get('uid', request.auth.uid) == request.auth.uid);
    }

    function isValidAlert(data) {
      return data.keys().hasAll(['productId', 'userId']) &&
             data.productId is string &&
             data.userId == request.auth.uid;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'message', 'date']) &&
             data.userId is string &&
             data.message is string && data.message.size() <= 500;
    }

    function isValidAnnouncement(data) {
      return data.keys().hasAll(['title', 'content', 'type', 'date']) &&
             data.title is string && data.title.size() <= 200;
    }

    function isValidStockAlert(data) {
      return data.keys().hasAll(['productId', 'userId']) &&
             data.productId is string &&
             data.userId == request.auth.uid;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'user', 'rating', 'comment', 'date']) &&
             data.productId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             (data.get('userId', '') == '' || data.userId == request.auth.uid || isAdmin());
    }

    // --- 4. COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (
        isOwner(userId) && 
        isValidUser(incoming()) && 
        incoming().get('uid', userId) == userId &&
        incoming().diff(existing()).affectedKeys().hasOnly([
          'username', 'photoURL', 'displayName', 'avatarUrl', 
          'likedProducts', 'updatedAt', 'password', 'email'
        ])
      ) || isAdmin();
      allow delete: if isAdmin();
    }

    // USERNAMES: Uniqueness registry and lookup
    match /usernames/{username} {
      allow get: if true;
      allow create: if isSignedIn() && incoming().get('uid', '') == request.auth.uid;
      allow update: if isSignedIn() && 
        (existing().get('uid', '') == request.auth.uid || existing().get('email', '') == request.auth.token.email) && 
        incoming().get('uid', '') == request.auth.uid;
      allow delete: if isSignedIn() && 
        (existing().get('uid', '') == request.auth.uid || existing().get('email', '') == request.auth.token.email || isAdmin());
      allow list: if isAdmin();
    }

    // PRODUCTS: Admin-only writes, public read
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // USER PREFS: Strictly private storage
    match /user_prefs/{userId} {
      // Support 'list' by ensuring the user only queries their own
      allow get: if isOwner(userId);
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isOwner(userId) && isValidUserPrefs(incoming());
      allow update: if isOwner(userId) && isValidUserPrefs(incoming());
      allow delete: if isOwner(userId) || isAdmin();
    }

    // PRODUCT ALERTS: Subscription-based isolation
    match /product_alerts/{alertId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidAlert(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidAlert(incoming());
      allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
    }

    // NOTIFICATIONS: Private inbox with admin sync
    match /notifications/{notifId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if (isVerified() && incoming().userId == request.auth.uid) || isAdmin();
      allow update: if (isSignedIn() && isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read'])) || isAdmin();
      allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
    }

    // ANNOUNCEMENTS: Public read, Admin write
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidAnnouncement(incoming());
      allow delete: if isAdmin();
    }

    // STOCK ALERTS: Private subscriptions
    match /stock_alerts/{alertId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidStockAlert(incoming());
      allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
    }

    // REVIEWS: Public read, User/Guest create, User/Admin delete
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReview(incoming());
      allow update: if (isSignedIn() && (existing().get('userId', '') == request.auth.uid || isAdmin())) && isValidReview(incoming());
      allow delete: if (isSignedIn() && (existing().get('userId', '') == request.auth.uid || isAdmin()));
    }
  }
}
