rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ==========================================
    // GLOBAL SAFETY NET
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // HELPERS
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'wilsondayritjrapex@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true))
      );
    }

    function getUsername() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ==========================================
    // VALIDATORS
    // ==========================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'email', 'avatarUrl', 'role']) &&
             data.username is string && data.username.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.role in ['user', 'admin'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'price', 'inStock']) &&
             data.id is string && data.id.size() <= 100 &&
             data.name is string && data.name.size() <= 300 &&
             data.category is string &&
             data.price is number &&
             data.inStock is bool;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'userId', 'message', 'date', 'read']) &&
             data.id is string && data.id.size() <= 200 &&
             data.userId is string && data.userId.size() <= 100 &&
             data.message is string && data.message.size() <= 1500 &&
             data.date is string &&
             data.read is bool;
    }

    function isValidUserPrefs(data) {
      return data.keys().hasAll(['savedIds', 'alertIds']) &&
             data.savedIds is list && data.savedIds.size() <= 1000 &&
             data.alertIds is list && data.alertIds.size() <= 1000;
    }

    // ==========================================
    // RULES
    // ==========================================

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid && 
                    isValidUser(incoming()) && incoming().role == 'user';
      allow update: if isSignedIn() && userId == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['avatarUrl', 'photoURL', 'displayName', 'username', 'password']) &&
                    isValidUser(incoming());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming()) && incoming().id == existing().id;
      allow delete: if isAdmin();
    }

    match /user_prefs/{username} {
      // Logic: Users can read/write their own. Admins can list all for alerts broadcast.
      allow get: if isSignedIn() && username == getUsername();
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && username == getUsername() && isValidUserPrefs(incoming());
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      // Logic: User can list their own notifications. Admin can create them.
      allow list: if isSignedIn() && resource.data.userId == getUsername();
      allow get: if isSignedIn() && resource.data.userId == getUsername();
      allow create: if isAdmin() && isValidNotification(incoming());
      allow update: if isSignedIn() && resource.data.userId == getUsername() && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']) &&
                    incoming().read == true;
      allow delete: if isSignedIn() && resource.data.userId == getUsername();
    }

    // Support collection for old code compatibility if any
    match /support_tickets/{ticketId} {
      allow read, write: if isSignedIn();
    }
  }
}
