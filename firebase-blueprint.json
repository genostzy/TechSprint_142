{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "isAdmin": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "PC component product listed in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "inStock": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserPrefs": {
      "title": "User Preferences",
      "description": "User specific preferences like saved product IDs.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "savedIds": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ProductAlert": {
      "title": "Product Alert Subscription",
      "description": "Subscription for price drop alerts on a specific product.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "System or price change notification for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Global system announcement or event.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["maintenance", "update", "event", "info"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "active": { "type": "boolean" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "UserReview": {
      "title": "User Review",
      "description": "Customer review for a specific product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "user": { "type": "string" },
        "productId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "rating"]
    },
    "StockAlert": {
      "title": "Stock Alert Subscription",
      "description": "Subscription for back-in-stock notifications.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId"]
    },
    "UsernameRegistry": {
      "title": "Username Registry",
      "description": "Mapping from username to UID and email for authentication and uniqueness.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profile documents."
    },
    "/usernames/{username}": {
      "schema": "UsernameRegistry",
      "description": "Unique mapping of usernames to ensure no duplicates and support username login."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products available in the system."
    },
    "/user_prefs/{userId}": {
      "schema": "UserPrefs",
      "description": "Private user preferences (saved items)."
    },
    "/product_alerts/{alertId}": {
      "schema": "ProductAlert",
      "description": "Subscriptions for price change notifications."
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "User-specific notifications."
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Global announcements visible to all users."
    },
    "/reviews/{reviewId}": {
      "schema": "UserReview",
      "description": "Product reviews from users."
    },
    "/stock_alerts/{alertId}": {
      "schema": "StockAlert",
      "description": "Subscriptions for back-in-stock notifications."
    }
  }
}
